{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track broadcom-sta insecure package pin",
      "managerFilePatterns": ["machines/[^/]+/configuration\\.nix$"],
      "matchStrings": ["\"broadcom-sta-(?<currentValue>[^\"]+)\""],
      "packageNameTemplate": "nix_stable_25_11/broadcom-sta",
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["nix_stable_25_11/broadcom-sta"],
      "reviewers": ["ndrwstn"],
      "assignees": ["ndrwstn"],
      "schedule": ["before 4am on Thursday"]
    }
  ]
}
