{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track broadcom-sta version in permittedInsecurePackages",
      "managerFilePatterns": ["machines/.*/configuration\\.nix$"],
      "matchStrings": ["broadcom-sta-(?<currentValue>[^\"]+)"],
      "depNameTemplate": "nixpkgs_unstable/broadcom-sta",
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["regex"],
      "matchDepNames": ["nixpkgs_unstable/broadcom-sta"],
      "reviewers": ["ndrwstn"],
      "assignees": ["ndrwstn"],
      "schedule": ["before 4am on Thursday"]
    }
  ]
}
