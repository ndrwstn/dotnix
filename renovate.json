{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track broadcom-sta version in permittedInsecurePackages",
      "managerFilePatterns": ["**/configuration.nix"],
      "matchStrings": ["broadcom-sta-(?<currentValue>[^\"]+)"],
      "depNameTemplate": "nixpkgs_25_11/broadcom-sta",
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["regex"],
      "matchDepNames": ["nixpkgs_25_11/broadcom-sta"],
      "reviewers": ["ndrwstn"],
      "assignees": ["ndrwstn"],
      "schedule": ["before 4am on Thursday"]
    }
  ]
}
